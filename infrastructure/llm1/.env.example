# Cairo Data Layer — environment template
#
# COPY THIS FILE TO /opt/cairo-data/.env ON llm1, FILL IN, chmod 0600.
# Do NOT commit a real .env to git.
#
# All values below are placeholders. Generate strong random secrets
# (e.g., `openssl rand -base64 32` or `pwgen -s 32 1`) per service.

# -----------------------------------------------------------------------------
# Tailscale auth keys — one per service.
# Generate in https://login.tailscale.com/admin/settings/keys
#   - Reusable: yes (so container restarts re-authenticate cleanly)
#   - Ephemeral: yes (state still lives in the bind-mounted /var/lib/tailscale,
#     but ephemeral keeps stale machine entries from accumulating)
#   - Tags: tag:cairo-data
# ACL note: your tailnet ACL must permit tag:cairo-data devices to be created
# and to be reachable from the clients that need them (e.g., tag:cairo-client,
# or specific user accounts).
# -----------------------------------------------------------------------------
TS_AUTHKEY_QDRANT=tskey-auth-REPLACE
TS_AUTHKEY_NEO4J=tskey-auth-REPLACE
TS_AUTHKEY_POSTGRES=tskey-auth-REPLACE
TS_AUTHKEY_REDIS=tskey-auth-REPLACE
TS_AUTHKEY_MINIO=tskey-auth-REPLACE

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_API_KEY=REPLACE_STRONG_RANDOM

# -----------------------------------------------------------------------------
# Neo4j — username is fixed to 'neo4j' by the image; password is yours.
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=REPLACE_STRONG_RANDOM

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=cairo
POSTGRES_PASSWORD=REPLACE_STRONG_RANDOM
POSTGRES_DB=cairo

# -----------------------------------------------------------------------------
# Redis — password-protected via `requirepass`.
# -----------------------------------------------------------------------------
REDIS_PASSWORD=REPLACE_STRONG_RANDOM

# -----------------------------------------------------------------------------
# MinIO — root creds. Create app-level access keys via the console after first boot.
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=cairoadmin
MINIO_ROOT_PASSWORD=REPLACE_STRONG_RANDOM
